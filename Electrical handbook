const Calculator = () => {
  const [mode, setMode] = useState("ohm");
  const [vals, setVals] = useState({ V: "", I: "", R: "", P: "" });
  const [result, setResult] = useState(null);
  const [error, setError] = useState("");

  const set = (k, v) => setVals(prev => ({ ...prev, [k]: v }));

  const solve = () => {
    setError("");
    setResult(null);
    const n = {};
    for (const k of ["V", "I", "R", "P"]) {
      if (vals[k] !== "") {
        const parsed = parseFloat(vals[k]);
        if (isNaN(parsed) || parsed < 0) { setError("Enter valid positive numbers."); return; }
        n[k] = parsed;
      }
    }
    const known = Object.keys(n);
    if (known.length < 2) { setError("Enter at least 2 known values."); return; }

    let V = n.V, I = n.I, R = n.R, P = n.P;

    if (V !== undefined && I !== undefined) { R = R ?? V / I; P = P ?? V * I; }
    else if (V !== undefined && R !== undefined) { I = I ?? V / R; P = P ?? V * V / R; }
    else if (I !== undefined && R !== undefined) { V = V ?? I * R; P = P ?? I * I * R; }
    else if (P !== undefined && V !== undefined) { I = I ?? P / V; R = R ?? V * V / P; }
    else if (P !== undefined && I !== undefined) { V = V ?? P / I; R = R ?? P / (I * I); }
    else if (P !== undefined && R !== undefined) { I = I ?? Math.sqrt(P / R); V = V ?? Math.sqrt(P * R); }
    else { setError("Cannot solve with these two values alone."); return; }

    const fmt = x => x !== undefined ? (Math.round(x * 10000) / 10000).toString() : "â€”";
    setResult({ V: fmt(V), I: fmt(I), R: fmt(R), P: fmt(P) });
  };

  const reset = () => { setVals({ V: "", I: "", R: "", P: "" }); setResult(null); setError(""); };

  return (
    <div style={{ background: "rgba(255,255,255,0.04)", borderRadius: 16, padding: 24, marginTop: 8 }}>
      <p style={{ color: "#94A3B8", fontSize: 13, marginBottom: 16 }}>
        Enter any 2 known values â€” the rest will be calculated.
      </p>
      <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 12, marginBottom: 16 }}>
        {[["V", "Voltage (V)", "Volts"], ["I", "Current (I)", "Amps"], ["R", "Resistance (R)", "Ohms"], ["P", "Power (P)", "Watts"]].map(([k, label, unit]) => (
          <div key={k}>
            <label style={{ color: "#94A3B8", fontSize: 12, display: "block", marginBottom: 4 }}>{label}</label>
            <div style={{ display: "flex", alignItems: "center", background: "rgba(255,255,255,0.06)", borderRadius: 8, overflow: "hidden", border: "1px solid rgba(255,255,255,0.1)" }}>
              <input
                type="number"
                value={vals[k]}
                onChange={e => set(k, e.target.value)}
                placeholder="?"
                style={{ flex: 1, background: "transparent", border: "none", outline: "none", color: "#F1F5F9", padding: "10px 12px", fontSize: 15 }}
              />
              <span style={{ color: "#64748B", fontSize: 12, paddingRight: 10 }}>{unit}</span>
            </div>
          </div>
        ))}
      </div>
      <div style={{ display: "flex", gap: 10, marginBottom: 16 }}>
        <button onClick={solve} style={{ flex: 1, background: "#F59E0B", color: "#000", border: "none", borderRadius: 8, padding: "11px 0", fontWeight: 700, fontSize: 15, cursor: "pointer", fontFamily: "inherit" }}>
          Calculate âš¡
        </button>
        <button onClick={reset} style={{ background: "rgba(255,255,255,0.08)", color: "#94A3B8", border: "none", borderRadius: 8, padding: "11px 18px", cursor: "pointer", fontFamily: "inherit" }}>
          Reset
        </button>
      </div>
      {error && <p style={{ color: "#EF4444", fontSize: 13, marginBottom: 12 }}>âš ï¸ {error}</p>}
      {result && (
        <div style={{ background: "rgba(245,158,11,0.08)", border: "1px solid rgba(245,158,11,0.3)", borderRadius: 12, padding: 16 }}>
          <p style={{ color: "#F59E0B", fontWeight: 700, marginBottom: 12, fontSize: 13 }}>RESULTS</p>
          <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 10 }}>
            {[["V", "Voltage", "V"], ["I", "Current", "A"], ["R", "Resistance", "Î©"], ["P", "Power", "W"]].map(([k, label, unit]) => (
              <div key={k} style={{ background: "rgba(255,255,255,0.05)", borderRadius: 8, padding: "10px 14px" }}>
                <div style={{ color: "#64748B", fontSize: 11, marginBottom: 2 }}>{label}</div>
                <div style={{ color: "#F1F5F9", fontSize: 18, fontWeight: 700 }}>{result[k]} <span style={{ fontSize: 12, color: "#94A3B8" }}>{unit}</span></div>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  );
};

